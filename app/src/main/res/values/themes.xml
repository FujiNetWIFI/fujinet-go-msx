<resources>
    <!--
      Edge-to-edge friendly: NO android:windowFullscreen (the legacy fullscreen
      flag fights enableEdgeToEdge() and, on Android 11 / API 30, hides the status
      bar so the top toolbar ends up under it). The activity calls
      enableEdgeToEdge() and the content uses Modifier.safeDrawingPadding(), so the
      system bars are transparent and the toolbar is inset below the status bar on
      every API level. A black window background avoids a launch flash before the
      Compose surface draws.
    -->
    <style name="Theme.FujiNetGoMsx" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!--
      Settings host: a translucent, no-background window so the Compose AlertDialog
      floats centered over the running emulator (the activity behind stays visible
      and is dimmed by the dialog's own scrim). backgroundDimEnabled is left off so
      the window doesn't double-dim on top of that scrim.
    -->
    <style name="Theme.FujiNetGoMsx.Settings" parent="Theme.FujiNetGoMsx">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
